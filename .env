# ============================================
# Medivault Smart Clinic - Environment Configuration
# ============================================
# This is a self-hosted medical clinic management system.

# ============================================
# Application Settings
# ============================================
# Set to True for development, False for production
DEBUG=True

# Django secret key - CHANGE THIS! Generate a new one for production
# You can generate one at: https://djecrety.ir/
SECRET_KEY='Change-Me-To-A-Strong-Secret-Key'

# Your site domain (used for OAuth callbacks and emails)
# Examples: 
#   Development: http://localhost:8000
#   Production: https://your-clinic-domain.com
SITE_DOMAIN='http://localhost:8000'

# ============================================
# Database Configuration
# ============================================
# Database type: 'postgresql' (recommended) or 'sqlite'
database_type='postgresql'

# PostgreSQL Database Settings (used when database_type='postgresql')
# If using Docker, these match the docker-compose.yml settings
DATABASE_NAME='medivaultclinic_db'
DATABASE_USER='medivaultclinic_user'
DATABASE_PASSWORD='medivaultclinic_password'
DATABASE_HOST='db'  # Use 'localhost' for non-Docker setups, 'db' for Docker

# For SQLite (development only), no additional configuration needed
# The database file will be created automatically as db.sqlite3

# ============================================
# Google OAuth (Optional)
# ============================================
# To enable Google login, create OAuth credentials at:
# https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google authentication
GOOGLE_CLIENT_ID=''
GOOGLE_CLIENT_SECRET=''

# ============================================
# Email Configuration (Optional)
# ============================================
# Used for sending password reset emails and notifications
# If not configured, email features will be disabled
# Supports Gmail, Outlook, or any SMTP server
MAIL_USER='hieunguyen109204@gmail.com'
MAIL_PASSWORD='uegw bvcc uzfs zxxp'

# For Gmail: Use an App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# Example: MAIL_USER='your-email@gmail.com'
#          MAIL_PASSWORD='your-app-password'

#database (Docker)
DATABASE_NAME='medivaultclinic_db'
DATABASE_USER='medivaultclinic_user'
DATABASE_PASSWORD='medivaultclinic_password'
DATABASE_HOST='db'

# This is your site domain (used for OAuth callbacks and emails)
SITE_DOMAIN = 'localhost:8000' 

# This is your database type based on your setup
database_type = 'postgresql'
# ============================================
# End of Configuration
